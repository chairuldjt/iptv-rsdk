datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Playlist {
  id            Int        @id @default(autoincrement())
  name          String
  filePath      String?
  sourceUrl     String?    @db.Text
  totalChannels Int        @default(0)
  isGlobal      Boolean?   @default(false)
  relayEnabled  Boolean    @default(false)
  relayConfig   String?    @db.Text
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  categories    Category[]
  channels      Channel[]
  devices       Device[]

  @@index([isGlobal])
  @@index([updatedAt])
}

model Category {
  id         Int       @id @default(autoincrement())
  playlistId Int
  playlist   Playlist  @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  name       String
  sortOrder  Int       @default(0)
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  channels   Channel[]

  @@index([playlistId, sortOrder])
}

model Channel {
  id         Int       @id @default(autoincrement())
  playlistId Int
  playlist   Playlist  @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  categoryId Int?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  name       String
  logoUrl    String?    @db.Text
  streamUrl  String     @db.Text
  sortOrder  Int       @default(0)
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([playlistId, isActive, sortOrder])
  @@index([categoryId])
}

model Device {
  id             Int           @id @default(autoincrement())
  deviceId       String        @unique
  deviceName          String        @default("Android STB")
  deviceNameUpdatedAt DateTime?
  isActive            Boolean       @default(true)
  playlistId     Int?
  playlist       Playlist?     @relation(fields: [playlistId], references: [id], onDelete: SetNull)
  appVersion     String?
  appVersionCode Int?
  androidVersion String?
  lastIp         String?
  macAddress     String?
  lastOnline     DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  config         DeviceConfig?
  logs           DeviceLog[]

  @@index([isActive, lastOnline])
  @@index([lastOnline])
  @@index([macAddress])
}

model DeviceConfig {
  id                    Int      @id @default(autoincrement())
  deviceId              String?  @unique
  device                Device?  @relation(fields: [deviceId], references: [deviceId], onDelete: Cascade)
  defaultCategory       String   @default("National TV")
  defaultChannelId      Int?
  aspectRatio           String   @default("fit") // "fit", "stretch", "zoom", "16_9", "4_3"
  syncInterval          Int      @default(1800) // seconds
  syncMode              String?  @default("custom") // "api" (centralized, relay follows playlist settings) or "custom" (M3U URL)
  customM3uUrl          String?  @db.Text
  startScreen           String   @default("live_tv") // "live_tv", "category_list", "home_screen"
  lockSettings          Boolean  @default(true)
  forceSync             Boolean  @default(false)
  clearCacheTrigger     Boolean? @default(false)
  autoStartOnBoot       Boolean  @default(false)
  technicianPin         String   @default("2468")
  educationVideoPath    String   @default("")
  educationSmbUsername  String   @default("")
  educationSmbPassword  String   @default("")
  educationSmbDomain    String   @default("")
  educationRepeatMode   String   @default("all")          // "all", "one", "none"
  educationPlayOrder    String   @default("alphabetical") // "alphabetical", "random", "shuffle"
  educationSource       String   @default("smb")          // "smb", "web"
  educationPlaybackMode String   @default("copy")         // "copy", "stream"
  educationForceSync    Boolean  @default(false)
  apiBaseUrl            String?  @db.Text
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model EducationVideo {
  id           Int              @id @default(autoincrement())
  folderId     Int?
  folder       EducationFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  title        String
  videoUrl     String           @db.Text
  thumbnailUrl String?          @db.Text
  isPublished  Boolean          @default(true)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([folderId])
  @@index([isPublished])
  @@index([updatedAt])
}

model EducationFolder {
  id        Int              @id @default(autoincrement())
  name      String           @unique
  isPublished Boolean        @default(true)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  videos    EducationVideo[]

  @@index([isPublished])
}

model EntertainmentItem {
  id           Int      @id @default(autoincrement())
  title        String
  subtitle     String   @default("")
  url          String?  @db.Text
  contentType  String   @default("webview") // "webview", "media_player", "m3u_player"
  thumbnailUrl String?  @db.Text
  isActive     Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([isActive, sortOrder])
}

model DeviceLog {
  id           Int      @id @default(autoincrement())
  deviceId     String
  device       Device   @relation(fields: [deviceId], references: [deviceId], onDelete: Cascade)
  errorType    String
  errorMessage String
  channelId    Int?
  streamUrl    String?
  androidSdk   Int?
  createdAt    DateTime @default(now())

  @@index([deviceId, createdAt])
  @@index([createdAt])
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String   // Hashed password
  role      String   @default("admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AppSetting {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}



model AppUpdate {
  id            Int      @id @default(autoincrement())
  versionCode   Int      @unique
  versionName   String
  apkFileName   String
  packageName   String?
  updateChannel String?
  changelog     String?  @db.Text
  isMandatory   Boolean  @default(false)
  isDeployed    Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
